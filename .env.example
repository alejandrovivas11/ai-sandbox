# Database connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/patient_mgmt

# Secret key for JWT token signing.
# IMPORTANT: Generate a strong unique key for every environment.
# Run: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY

# JWT algorithm
ALGORITHM=HS256

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment: "development" or "production"
# In production, SECRET_KEY validation is enforced (min 32 chars, no default).
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8001"]
